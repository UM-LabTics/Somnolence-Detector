# ─────────────────────────────────────────────────────────────────────────
# Variables de entorno del detector en la Raspberry Pi (Parte 5).
#
# Copiá este archivo a /etc/somnolence.env en la Pi y completá las rutas:
#     sudo cp somnolence.env.example /etc/somnolence.env
#     sudo nano /etc/somnolence.env
#
# El systemd unit lo carga con EnvironmentFile=. NO lo commitees con datos
# reales (de hecho /etc/somnolence.env vive fuera del repo).
# ─────────────────────────────────────────────────────────────────────────

# --- Broker: AWS IoT Core (TLS) ---
MQTT_BROKER=a3658r5b4lb2u7-ats.iot.us-east-2.amazonaws.com
MQTT_PORT=8883
MQTT_TOPIC_PREFIX=somnolence

# client_id: debe coincidir con el Thing creado en IoT Core.
# Cada Pi necesita su propio client_id + su propio Thing/certificado.
MQTT_CLIENT_ID=somnolence-pi-team06

# --- Certificados (mutual TLS) — mismos nombres que el backend ---
# Rutas absolutas en la Pi a los 3 archivos copiados por scp desde certs/pi/.
MQTT_CA_CERT=/home/pi/somnolence/certs/AmazonRootCA1.pem
MQTT_CLIENT_CERT=/home/pi/somnolence/certs/2bea4010...-certificate.pem.crt
MQTT_CLIENT_KEY=/home/pi/somnolence/certs/2bea4010...-private.pem.key

# --- Runtime ---
# headless=true: sin ventana de OpenCV (obligatorio bajo systemd / SSH sin display).
HEADLESS=true

# Sensores/actuadores reales en la Pi -> false. Mock para probar sin hardware.
MOCK_SENSORS=true
MOCK_ACTUATORS=true

# Opcional: forzar un device_id fijo (si no, usa detector/.device_id).
# DEVICE_ID=d0f9d7cc-1456-43e6-a23b-dd8b2434c287
